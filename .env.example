# Fisheries Research Agents - environment configuration
# Copy to `.env` and fill in. NEVER commit a real `.env`.

# --- LLM (Anthropic) ---------------------------------------------------------
# Required for the Planner, Synthesis, and Critic agents.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the default model string (see config/connectors.yaml -> llm.model).
FRA_LLM_MODEL=claude-sonnet-5

# --- Connector API keys ------------------------------------------------------
# Each is optional. A connector whose key is missing is auto-disabled and its
# data domain is reported as a coverage gap rather than failing the run.

# Copernicus Marine Service (oceanographic gridded data).
COPERNICUS_MARINE_USERNAME=
COPERNICUS_MARINE_PASSWORD=

# NOAA ERDDAP / NCEI - most ERDDAP servers need no key; set a base override if desired.
ERDDAP_BASE_URL=

# Crossref is keyless but asks for a mailto in the User-Agent (polite pool).
CROSSREF_MAILTO=you@example.org

# OpenAlex is keyless; a mailto also gets you the polite pool.
OPENALEX_MAILTO=you@example.org

# --- Runtime -----------------------------------------------------------------
# On-disk connector cache location (defaults to ./.fra_cache).
FRA_CACHE_DIR=.fra_cache
